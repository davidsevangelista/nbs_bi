# Paste the contents of this file into the Streamlit Cloud Secrets UI.
# Do NOT commit .streamlit/secrets.toml — it is gitignored.

READONLY_DATABASE_URL = "postgresql://user:password@host:5432/dbname"

# Optional: set to "" to use default path (data/processed/db_cache)
# On Streamlit Cloud the cache is ephemeral — leave empty.
DB_CACHE_DIR = ""
