# NBS BI — Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env.

# Database (example: PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/nbs_db

# Rain API (if fetching invoices programmatically in the future)
RAIN_API_KEY=

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
